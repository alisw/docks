{
  "_comment": "Alma 8.7 builder X-enabled",
  "builders": [
    {
      "changes": [
        "ENTRYPOINT [\"\"]",
        "CMD [\"/bin/bash\"]"
      ],
      "commit": true,
      "image": "almalinux:8.7",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `REPO`}}",
        "tags": [
          "{{user `TAG`}}"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "environment_vars": [
        "GIT_VERSION={{user `GIT_VERSION`}}"
      ],
      "script": "provision.sh",
      "type": "shell"
    }
  ],
  "variables": {
    "GIT_VERSION": "2.32.0",
    "REPO": "registry.cern.ch/alisw/slc8-builder",
    "TAG": "latest"
  }
}

