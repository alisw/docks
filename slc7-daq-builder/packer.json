{
  "_comment": "Builder with Centos7 and devtools4",
  "builders": [
    {
      "commit": true,
      "image": "centos:centos7",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `DOCKER_HUB_REPO`}}/slc7-daq-builder",
        "tags": [
          "latest"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "script": "provision.sh",
      "type": "shell"
    }
  ],
  "variables": {
    "DOCKER_HUB_REPO": "alisw"
  }
}

