{
  "_comment": "Build a rsync image",
  "builders": [
    {
      "commit": true,
      "image": "centos:centos{{user `centos_major`}}",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `REPO`}}",
        "tags": [
          "{{user `TAG`}}"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "destination": "/run.sh",
      "source": "run.sh",
      "type": "file"
    },
    {
      "inline": [
        "yum update -y \u0026\u0026 yum install -y rsync nc \u0026\u0026 yum clean all"
      ],
      "type": "shell"
    }
  ],
  "variables": {
    "REPO": "registry.cern.ch/alisw/rsync",
    "TAG": "latest",
    "centos_major": "7"
  }
}

