{
  "_comment": "CentOS 7 with devtoolset-6",
  "builders": [
    {
      "commit": true,
      "image": "alisw/slc7-builder",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `DOCKER_HUB_REPO`}}/slc7-devtoolset",
        "tags": [
          "latest"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "inline": [
        "yum clean all",
        "rpm --rebuilddb",
        "yum install -y centos-release-scl",
        "yum install -y devtoolset-6"
      ],
      "type": "shell"
    }
  ],
  "variables": {
    "DOCKER_HUB_REPO": "alisw"
  }
}

