{
  "_comment": "Build an elasticsearch image",
  "builders": [
    {
      "commit": true,
      "image": "elasticsearch:{{user `elasticsearch_version`}}",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `DOCKER_HUB_REPO`}}/elasticsearch",
        "tags": [
          "{{user `elasticsearch_version`}}"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "inline": [
        "/usr/share/elasticsearch/bin/plugin install mobz/elasticsearch-head/latest"
      ],
      "type": "shell"
    }
  ],
  "variables": {
    "DOCKER_HUB_REPO": "alisw",
    "elasticsearch_version": "2.4"
  }
}

