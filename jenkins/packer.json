{
  "_comment": "Jenkins service",
  "builders": [
    {
      "changes": [
        "ENTRYPOINT [\"\"]",
        "CMD [\"\"]"
      ],
      "commit": true,
      "image": "centos:centos7",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `REPO`}}",
        "tags": [
          "{{user `jenkins_version`}}"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "destination": "/run.sh",
      "source": "run.sh",
      "type": "file"
    },
    {
      "script": "provision.sh",
      "type": "shell"
    }
  ],
  "variables": {
    "REPO": "registry.cern.ch/alisw/jenkins",
    "jenkins_version": "2.46.3"
  }
}

