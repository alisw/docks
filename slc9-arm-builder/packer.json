{
  "_comment": "Alma 9 builder",
  "builders": [
    {
      "changes": [
        "ENTRYPOINT [\"\"]",
        "CMD [\"/bin/bash\"]"
      ],
      "commit": true,
      "image": "gitlab-registry.cern.ch/linuxsupport/alma9-base:9.7",
      "type": "docker"
    }
  ],
  "post-processors": [
    [
      {
        "repository": "{{user `REPO`}}",
        "tags": [
          "{{user `TAG`}}"
        ],
        "type": "docker-tag"
      },
      {
        "inline": [
          "echo 'The image was built successfully. To push the image to the registry, you can run: docker push {{user `REPO`}}:{{user `TAG`}}'"
        ],
        "type": "shell-local"
      }
    ]
  ],
  "provisioners": [
    {
      "destination": "/etc/yum.repos.d/alice-system-deps.repo",
      "source": "alice-system-deps.repo",
      "type": "file"
    },
    {
      "script": "provision.sh",
      "type": "shell"
    }
  ],
  "variables": {
    "REPO": "registry.cern.ch/alisw/slc9-arm-builder",
    "TAG": "latest"
  }
}

